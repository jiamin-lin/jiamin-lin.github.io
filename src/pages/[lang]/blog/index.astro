---
import PostCard from '../../../components/PostCard.astro';
import { homeCopy, languages, type Lang } from '../../../data/site';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../../../lib/content';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const posts = await getPublishedPosts(lang);
---

<BaseLayout title={homeCopy[lang].latest} description={homeCopy[lang].description} lang={lang}>
  <section class="shell section-block">
    <div class="section-heading">
      <div>
        <p class="eyebrow">{lang}</p>
        <h1>{homeCopy[lang].latest}</h1>
      </div>
    </div>

    {posts.length > 0 ? (
      <div class="post-grid">
        {posts.map((post) => <PostCard post={post} localized />)}
      </div>
    ) : (
      <p class="empty-state">{homeCopy[lang].empty}</p>
    )}
  </section>
</BaseLayout>
