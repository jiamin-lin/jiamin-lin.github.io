---
import { languageLabels, languages, navItems, site } from '../data/site';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<header class="site-header">
  <div class="shell header-shell">
    <a class="brand" href="/" aria-label={`${site.name} home`}>
      <span class="brand-mark">DR</span>
      <span>
        <strong>{site.name}</strong>
        <small>Cloud Field Notes</small>
      </span>
    </a>

    <nav class="main-nav" aria-label="Primary navigation">
      {navItems.map((item) => (
        <a class:list={[currentPath === item.href && 'active']} href={item.href}>{item.label}</a>
      ))}
    </nav>

    <nav class="language-nav" aria-label="Language navigation">
      {languages.map((lang) => (
        <a href={`/${lang}/`}>{languageLabels[lang]}</a>
      ))}
    </nav>

    <button class="theme-toggle" type="button" aria-label="Toggle dark mode" aria-pressed="false" data-theme-toggle>
      <svg class="theme-icon theme-icon-sun" viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
      </svg>
      <svg class="theme-icon theme-icon-moon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M21 14.8A8.5 8.5 0 0 1 9.2 3a7 7 0 1 0 11.8 11.8Z"></path>
      </svg>
    </button>
  </div>
</header>
